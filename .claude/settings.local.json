{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:mastra.ai)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:aws.amazon.com)",
      "Bash(npm install:*)",
      "Bash(npm view:*)",
      "Bash(npm search:*)",
      "WebFetch(domain:www.npmjs.com)",
      "Bash(npm run build:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(./node_modules/.bin/tsx:*)",
      "Bash(uv run:*)",
      "Bash(npm show:*)"
    ]
  }
}
